NODE_ENV=development
HOST=127.0.0.1
PORT=3000
DEBUG=true

BODY_LIMIT=1mb
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Comma-separated origins. Leave empty to keep CORS closed by default.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required only if you enable CSRF in src/app.ts.
CSRF_SECRET=replace-with-at-least-32-random-characters

# Comma-separated keys allowed to load /docs and execute requests from it.
DOCS_KEYS=dev-docs-key
