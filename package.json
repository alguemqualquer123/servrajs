{
  "name": "servrajs",
  "version": "1.0.3",
  "description": "Lightweight Optimized Application - Ultrafast, Secure, Modern backend framework for Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "servra": "bin/servra.js"
  },
  "files": [
    "dist",
    "bin",
    "docs",
    "tests",
    "templates",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocols": {
      "types": "./dist/protocols/index.d.ts",
      "import": "./dist/protocols/index.js"
    },
    "./resilience": {
      "types": "./dist/resilience/index.d.ts",
      "import": "./dist/resilience/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alguemqualquer123/servrajs.git"
  },
  "homepage": "https://github.com/alguemqualquer123/servrajs#readme",
  "bugs": {
    "url": "https://github.com/alguemqualquer123/servrajs/issues"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "test": "node scripts/build.js && node tests/index.js",
    "typecheck": "tsc --noEmit",
    "prepack": "node scripts/build.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public",
    "release:beta": "npm version prerelease --no-git-tag-version && npm run build && npm publish --access public --tag beta"
  },
  "keywords": [
    "framework",
    "http",
    "server",
    "rest",
    "api",
    "performance",
    "security",
    "fast",
    "nodejs"
  ],
  "author": {
    "name": "SR VINIX",
    "email": "danilovinicius17@gmail.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "@types/node": "^20.10.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  }
}
